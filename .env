# ==============================================================================
# SEBI CO-PILOT CONFIGURATION ENV TEMPLATE
# ==============================================================================

# 1. Relational Database Settings
# Default: Runs with sqlite:///./sebi_copilot.db in-memory fallback
# If you are using PostgreSQL in Docker, uncomment and customize:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sebi_copilot
DATABASE_URL=sqlite:///./sebi_copilot.db

# 2. Backing Databases & Queues
# Defaults connect to standard local container ports
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# 3. Large Language Model (LLM) API Keys
# Paste your keys here to activate LangGraph agent extraction.
# If left blank, the system automatically falls back to procedural, rule-based extraction
# and search engines so you can fully review the system offline.
GEMINI_API_KEY=
OPENAI_API_KEY=

# 4. Security Options
JWT_SECRET=sebi_copilot_super_secret_key_change_me_in_prod
